{
  "$schema": "https://acme.com.br/forge/manifest-v1.json",
  "manifest_version": "0.2.0",
  "framework": {
    "name": "Acme Forge",
    "version": "0.2.0",
    "phase": "Forge-0 complete (v0.2.0)",
    "last_updated": "2026-04-30",
    "constitution_version": "0.2.0",
    "constitution_path": ".claude/CONSTITUTION.md",
    "constitution_sha256": null,
    "owner": "Acme / Novais Digital",
    "license": "private",
    "consumer_types": [
      {
        "type": "human-developer",
        "entry_point": "QUICKSTART.md",
        "tooling": "Claude Code IDE"
      },
      {
        "type": "deep-agent",
        "entry_point": "DEEPAGENT_GUIDE.md",
        "tooling": "GPT-5.5 via OpenAI SDK (Python deepagents OR Node @langchain/langgraph)"
      },
      {
        "type": "framework-maintainer",
        "entry_point": "CONTRIBUTING.md",
        "tooling": "Claude Code IDE + git"
      }
    ],
    "reviewer": {
      "type": "deep-agent",
      "model": "gpt-5.5",
      "provider": "openai",
      "frequency": "monthly",
      "contract_path": "docs/forge/reviewer-contract.md",
      "implementation_status": "specified-not-implemented",
      "implementation_target": "Forge-3",
      "artifacts": {
        "prompt": "reviewer/prompt.template.md",
        "output_schema": "reviewer/output-schema.json",
        "validation_rules": "reviewer/validation-rules.json",
        "example_audit": "reviewer/example-audit.md"
      }
    }
  },
  "principles": [
    {"id": "C1", "name": "Diagnose-before-design", "scope": "all-categories"},
    {"id": "C2", "name": "Outcome-first, never tech-first", "scope": "all-categories"},
    {"id": "C3", "name": "Cost ≤ 25% of price", "scope": "all-categories", "shadow_exemption": true},
    {"id": "C4", "name": "SHADOW antes de cobrar", "scope": "platform-skus", "products_alternative": "Beta declared"},
    {"id": "C5", "name": "Three-tier context", "scope": "all-categories"},
    {"id": "C6", "name": "Telemetry-by-default", "scope": "all-categories"},
    {"id": "C7", "name": "Portability over lock-in", "scope": "all-categories", "products_relax": "stack divergente em Beta com plano de migração"},
    {"id": "C8", "name": "Anti-customização heroica", "scope": "all-categories"}
  ],
  "principle_extensions_path": "examples/acme/constitution-extension.md",
